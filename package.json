{
  "name": "topfripe",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:backend": "npm --workspace apps/backend run dev",
    "build": "npm --workspace apps/frontend run build",
    "start": "npm --workspace apps/backend run start",
    "lint": "npm --workspace apps/frontend run lint"
  },
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
